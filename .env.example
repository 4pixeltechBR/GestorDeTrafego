# ========================================
# 🚀 GESTOR DE TRÁFEGO IA — Configuração
# ========================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha com suas chaves pessoais
# 3. NUNCA compartilhe o arquivo .env!
#
# Obtenha suas chaves gratuitas:
# - Groq:       https://console.groq.com/keys
# - Google AI:  https://aistudio.google.com/apikey
# - NVIDIA NIM: https://build.nvidia.com (Developer Program)
# - OpenRouter: https://openrouter.ai/keys
# - Meta Ads:   https://developers.facebook.com
# ========================================

# --- APIs de IA (Configure pelo menos 1) ---
GROQ_API_KEY=
GOOGLE_AI_KEY=
NVIDIA_NIM_KEY=
OPENROUTER_KEY=

# --- Meta Ads ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# --- Telegram (Opcional — para modo Copiloto) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Guardrails de Segurança ---
BUDGET_MAX_DIARIO=100
BUDGET_MAX_MENSAL=3000
# copilot = IA sugere, humano aprova via Telegram
# auto    = IA executa com hard-caps (sem aprovação)
APPROVAL_MODE=copilot

# --- Sistema ---
APP_NAME=GestorDeTrafego
PORT=8080
LOG_LEVEL=INFO
